{
  "version": "1.0.0",
  "name": "Bodulica Web Dev Agent",
  "description": "OpenClaw agent for web development via Windsurf Cascade",
  "default_skill": "web-development",
  "skills": {
    "web-development": {
      "enabled": true,
      "priority": "critical",
      "path": "/home/sovereign/linux/Bodulica/openclaw_integration/skills/web-development",
      "schedule": {
        "health_check": "*/5 * * * *",
        "auto_fix": "0 */1 * * *",
        "deploy_check": "0 0 * * *"
      },
      "projects": ["bodulica.shop"],
      "ai_assistants": {
        "deepseek_api": {
          "enabled": true,
          "api_key": "${DEEPSEEK_API_KEY}",
          "model": "deepseek-chat",
          "base_url": "https://api.deepseek.com/v1",
          "free_tier": {"enabled": true, "daily_limit_tokens": 1000000}
        },
        "ollama_local": {
          "enabled": true,
          "host": "http://localhost:11434",
          "model": "deepseek-r1:1.5b",
          "fallback": true
        }
      },
      "environment": {
        "primary_ide": "windsurf",
        "agent": "cascade",
        "platforms": ["supabase", "cloudflare", "github"],
        "workflow": "cascade_agent_orchestrated"
      }
    }
  },
  "endpoints": {
    "ollama": "http://localhost:11434"
  },
  "logging": {
    "level": "info",
    "file": "/tmp/openclaw.log",
    "max_size": "10MB",
    "max_files": 3
  }
}
