{
  "version": "1.0.0",
  "name": "Celestial Oracle Gateway",
  "description": "OpenClaw gateway for astrology platform",
  "default_skill": "astrology-core",
  "skills": {
    "astrology-core": {
      "enabled": true,
      "priority": "high",
      "path": "/home/sovereign/CascadeProjects/Celestial-Oracle/openclaw_integration/skills/astrology-core",
      "api_key": "${ASTROLOGY_API_KEY}",
      "rate_limit": {
        "requests_per_minute": 100,
        "requests_per_hour": 1000
      },
      "cache_ttl": 300,
      "timeout": 30
    },
    "monitoring-health": {
      "enabled": true,
      "priority": "critical",
      "path": "/home/sovereign/CascadeProjects/Celestial-Oracle/openclaw_integration/skills/monitoring-health",
      "schedule": {
        "health_check": "0 */6 * * *",
        "database_maintenance": "0 0 * * *",
        "daily_report": "0 0 * * *"
      }
    },
    "notifications-bot": {
      "enabled": true,
      "priority": "medium",
      "path": "/home/sovereign/CascadeProjects/Celestial-Oracle/openclaw_integration/skills/notifications-bot",
      "schedule": {
        "daily_horoscope_blast": "0 8 * * *"
      }
    },
    "content-generation": {
      "enabled": true,
      "priority": "medium",
      "path": "/home/sovereign/CascadeProjects/Celestial-Oracle/openclaw_integration/skills/content-generation",
      "ollama": {
        "host": "http://localhost:11434",
        "model": "deepseek-r1:1.5b",
        "timeout": 60
      },
      "schedule": {
        "generate_daily_horoscopes": "0 6 * * *",
        "batch_generate_content": "0 6 * * *"
      }
    },
    "payment-stripe": {
      "enabled": true,
      "priority": "high",
      "path": "/home/sovereign/CascadeProjects/Celestial-Oracle/openclaw_integration/skills/payment-stripe"
    },
    "claude-code-assistant": {
      "enabled": true,
      "priority": "high",
      "path": "/home/sovereign/CascadeProjects/Celestial-Oracle/openclaw_integration/skills/claude-ai",
      "api_key": "${CLAUDE_API_KEY}",
      "schedule": {
        "code_review": "0 2 * * *",
        "log_analysis": "0 */4 * * *",
        "system_optimization": "0 3 * * 0"
      }
    },
    "web-development": {
      "enabled": true,
      "priority": "critical",
      "path": "/home/sovereign/linux/Bodulica/openclaw_integration/skills/web-development",
      "schedule": {
        "health_check": "*/5 * * * *",
        "auto_fix": "0 */1 * * *",
        "deploy_check": "0 0 * * *"
      },
      "projects": ["bodulica.shop"],
      "ai_assistants": {
        "ollama": {"enabled": true, "model": "deepseek-r1:1.5b"},
        "claude": {"enabled": true}
      }
    }
  },
  "endpoints": {
    "api_base": "${ASTROLOGY_API_URL}",
    "webhook_base": "${ASTROLOGY_API_URL}/api/webhooks",
    "health": "${ASTROLOGY_API_URL}/health"
  },
  "notifications": {
    "telegram": {
      "enabled": true,
      "bot_token": "${TELEGRAM_BOT_TOKEN}",
      "admin_chat_id": "${ADMIN_CHAT_ID}"
    },
    "discord": {
      "enabled": false
    }
  },
  "logging": {
    "level": "info",
    "file": "/var/log/openclaw/agent.log",
    "max_size": "10MB",
    "max_files": 5
  }
}
